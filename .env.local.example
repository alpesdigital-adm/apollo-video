GROQ_API_KEY=gsk_...
GROQ_TRANSCRIBE_MODEL=whisper-large-v3
NEXT_PUBLIC_APP_URL=http://localhost:3333

# Apollo has one persistence model: PostgreSQL through the canonical V2 schema.
V2_DATABASE_URL=postgresql://apollo:change-me@localhost:5432/apollo_v2?schema=public
APOLLO_API_ENVIRONMENT=sandbox

# Browser login and external API authentication are both implemented by /v1.
APOLLO_UI_USERNAME=admin
APOLLO_UI_API_CLIENT_ID=apollo-ui-local
APOLLO_UI_PASSWORD_HASH=scrypt$replace-with-salt$replace-with-64-character-hex-hash
APOLLO_UI_SESSION_SECRET=replace-with-at-least-32-random-characters

# Protected recipe/RenderInput payloads. The key must decode to exactly 32 bytes.
APOLLO_PROTECTED_PAYLOAD_KEY_ID=local-v1
APOLLO_PROTECTED_PAYLOAD_KEY=replace-with-base64url-encoded-32-byte-key

# Reconstruction preflight fails closed unless the exact deployed renderer
# digest matches the digest embedded in RenderInput v1.
APOLLO_RENDERER_ID=remotion
APOLLO_RENDERER_VERSION=4.0.489
APOLLO_RENDERER_DIGEST=replace-with-64-character-sha256

# Absolute root visible only to the media/render worker. Canonical artifact
# keys are resolved below this directory and are never returned by public APIs.
APOLLO_V2_ARTIFACT_ROOT=C:/apollo/artifacts

# Private render output root. Outputs are staged as sibling partials and only
# promoted after the worker repeats materialization and rights revalidation.
APOLLO_V2_RENDER_OUTPUT_ROOT=C:/apollo/render-outputs
APOLLO_V2_RENDER_TIMEOUT_MS=1200000

# Durable render worker. Lease must be longer than heartbeat; poll controls how
# often an idle process checks for another persisted operation.
APOLLO_V2_WORKER_LEASE_MS=30000
APOLLO_V2_WORKER_HEARTBEAT_MS=10000
APOLLO_V2_WORKER_POLL_MS=1000
