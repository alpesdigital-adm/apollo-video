// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id                String   @id @default(cuid())
  name              String
  format            String   @default("9:16")
  status            String   @default("created")
  rawVideoPath      String?
  normalizedPath    String?
  renderedVideoPath String?
  videoDuration     Float?
  videoWidth        Int?
  videoHeight       Int?
  videoFps          Int?
  transcriptionJson String?
  subtitlesJson     String?
  silencesJson      String?
  engineKind        String   @default("narrative")
  stylePreset       String   @default("creator-clean")
  editPlanJson      String?
  scenesJson        String?
  paletteJson       String?
  narrativeFormat   String?
  error             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  renderJobs RenderJob[]
}

model RenderJob {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status     String   @default("queued")
  outputPath String?
  error      String?
  progress   Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([projectId])
}

// Apollo v2 foundation models. These names stay isolated from the legacy v1
// aggregate while the new domain is introduced incrementally.
model V2Workspace {
  id        String   @id
  slug      String   @unique
  name      String
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects              V2Project[]
  snapshots             V2ProjectSnapshot[]
  apiClients            V2ApiClient[]
  idempotencyRecords    V2IdempotencyRecord[]
  mediaArtifacts        V2MediaArtifact[]
  mediaManifests        V2MediaArtifactManifest[]
  mediaLineage          V2MediaArtifactLineage[]
  recipeParameters      V2RecipeParameterPayload[]
  renderInputs          V2RenderInputPayload[]
  rightsSnapshots       V2AssetRightsSnapshot[]
  materializations      V2MaterializationAuthorization[]
  assetUseDecisions     V2AssetUseDecision[]
  publicOperations      V2PublicOperation[]
  renderOperations      V2ArtifactRenderOperation[]
  publicEventOutbox     V2PublicEventOutbox[]
  webhookEndpoints      V2WebhookEndpoint[]
  webhookSecrets        V2WebhookSigningSecret[]
  webhookSubscriptions  V2WebhookSubscription[]
  webhookDeliveries     V2WebhookDelivery[]
  webhookAttempts       V2WebhookDeliveryAttempt[]
  webhookChallenges     V2WebhookVerificationChallenge[]
  webhookReplayReceipts V2WebhookReplayReceipt[]

  @@map("v2_workspaces")
}

model V2ApiClient {
  id          String    @id
  workspaceId String
  name        String
  status      String    @default("active")
  environment String    @default("sandbox")
  scopesJson  String
  secretSalt  String
  secretHash  String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastUsedAt  DateTime?

  workspace                   V2Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  credentials                 V2ApiCredential[]
  operations                  V2PublicOperation[]
  createdWebhookEndpoints     V2WebhookEndpoint[]     @relation("V2WebhookEndpointCreator")
  createdWebhookSubscriptions V2WebhookSubscription[] @relation("V2WebhookSubscriptionCreator")

  @@unique([id, workspaceId])
  @@index([workspaceId, status])
  @@map("v2_api_clients")
}

model V2ApiCredential {
  id          String    @id
  workspaceId String
  clientId    String
  status      String    @default("active")
  secretSalt  String
  secretHash  String
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?
  revokedAt   DateTime?

  client V2ApiClient @relation(fields: [clientId, workspaceId], references: [id, workspaceId], onDelete: Cascade)

  @@unique([id, clientId])
  @@index([clientId, status])
  @@index([workspaceId, status])
  @@index([expiresAt])
  @@map("v2_api_credentials")
}

model V2Project {
  id               String   @id
  workspaceId      String
  name             String
  status           String   @default("draft")
  currentVersionId String?
  createdByType    String
  createdById      String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspace      V2Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  versions       V2ProjectVersion[]  @relation("V2ProjectVersions")
  snapshots      V2ProjectSnapshot[]
  currentVersion V2ProjectVersion?   @relation("V2CurrentProjectVersion", fields: [currentVersionId, workspaceId], references: [id, workspaceId], onDelete: Restrict)

  @@unique([id, workspaceId])
  @@index([workspaceId, createdAt])
  @@index([workspaceId, status])
  @@map("v2_projects")
}

model V2ProjectSnapshot {
  id            String   @id
  workspaceId   String
  projectId     String
  kind          String
  schemaVersion Int
  contentJson   String
  contentHash   String
  createdAt     DateTime @default(now())

  workspace        V2Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  project          V2Project          @relation(fields: [projectId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  editPlanVersions V2ProjectVersion[] @relation("V2EditPlanSnapshot")
  policyVersions   V2ProjectVersion[] @relation("V2PoliciesSnapshot")

  @@unique([projectId, kind, contentHash])
  @@index([workspaceId, kind])
  @@map("v2_project_snapshots")
}

model V2ProjectVersion {
  id                 String   @id
  workspaceId        String
  projectId          String
  sequence           Int
  parentVersionId    String?
  editPlanSnapshotId String
  policiesSnapshotId String
  baseHash           String
  createdBy          String
  commandId          String?
  createdAt          DateTime @default(now())

  project            V2Project          @relation("V2ProjectVersions", fields: [projectId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  currentForProjects V2Project[]        @relation("V2CurrentProjectVersion")
  parent             V2ProjectVersion?  @relation("V2VersionParent", fields: [parentVersionId], references: [id], onDelete: SetNull)
  children           V2ProjectVersion[] @relation("V2VersionParent")
  editPlanSnapshot   V2ProjectSnapshot  @relation("V2EditPlanSnapshot", fields: [editPlanSnapshotId], references: [id], onDelete: Restrict)
  policiesSnapshot   V2ProjectSnapshot  @relation("V2PoliciesSnapshot", fields: [policiesSnapshotId], references: [id], onDelete: Restrict)

  @@unique([projectId, sequence])
  @@unique([id, workspaceId])
  @@index([workspaceId, createdAt])
  @@map("v2_project_versions")
}

model V2IdempotencyRecord {
  id                 String   @id
  workspaceId        String
  clientId           String
  key                String
  requestFingerprint String
  status             String
  responseStatus     Int?
  responseJson       String?
  expiresAt          DateTime
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  workspace V2Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, clientId, key])
  @@index([expiresAt])
  @@map("v2_idempotency_records")
}

model V2MediaArtifact {
  id                      String   @id
  workspaceId             String
  artifactKey             String
  sha256                  String
  byteSize                BigInt
  mediaType               String
  container               String
  status                  String   @default("available")
  currentRightsSnapshotId String?
  rightsRevision          Int      @default(0)
  createdAt               DateTime @default(now())

  workspace              V2Workspace                      @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  manifests              V2MediaArtifactManifest[]
  lineageUses            V2MediaArtifactLineage[]         @relation("V2MediaLineageSource")
  rightsSnapshots        V2AssetRightsSnapshot[]          @relation("V2AssetRightsSnapshots")
  currentRightsSnapshot  V2AssetRightsSnapshot?           @relation("V2CurrentAssetRights", fields: [currentRightsSnapshotId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  consentEvidenceFor     V2AssetRightsSnapshot[]          @relation("V2ConsentDocument")
  materializationTargets V2MaterializationAuthorization[] @relation("V2MaterializationTarget")
  renderOperationTargets V2ArtifactRenderOperation[]      @relation("V2ArtifactRenderTarget")

  @@unique([id, workspaceId])
  @@unique([workspaceId, artifactKey])
  @@index([workspaceId, sha256])
  @@index([workspaceId, mediaType, status])
  @@index([workspaceId, currentRightsSnapshotId])
  @@map("v2_media_artifacts")
}

model V2MediaArtifactManifest {
  id                  String   @id
  workspaceId         String
  artifactId          String
  schemaVersion       String
  manifestHash        String
  recipeId            String
  recipeVersion       String
  parametersHash      String
  recipeParametersRef String?
  renderInputRef      String?
  renderInputHash     String?
  manifestJson        String
  createdAt           DateTime @default(now())

  workspace        V2Workspace                      @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  artifact         V2MediaArtifact                  @relation(fields: [artifactId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  lineageEdges     V2MediaArtifactLineage[]
  recipeParameters V2RecipeParameterPayload?        @relation(fields: [recipeParametersRef, workspaceId], references: [ref, workspaceId], onDelete: Restrict)
  renderInput      V2RenderInputPayload?            @relation(fields: [renderInputRef, workspaceId], references: [ref, workspaceId], onDelete: Restrict)
  materializations V2MaterializationAuthorization[]
  renderOperations V2ArtifactRenderOperation[]

  @@unique([id, workspaceId])
  @@unique([artifactId, manifestHash])
  @@index([workspaceId, recipeId, recipeVersion])
  @@index([workspaceId, createdAt])
  @@index([workspaceId, recipeParametersRef])
  @@index([workspaceId, renderInputRef])
  @@map("v2_media_artifact_manifests")
}

model V2RecipeParameterPayload {
  ref               String
  workspaceId       String
  parametersHash    String
  canonicalByteSize Int
  algorithm         String
  keyId             String
  nonce             String
  ciphertext        String
  authTag           String
  createdAt         DateTime @default(now())

  workspace V2Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  manifests V2MediaArtifactManifest[]

  @@id([workspaceId, ref])
  @@unique([workspaceId, parametersHash])
  @@index([workspaceId, createdAt])
  @@map("v2_recipe_parameter_payloads")
}

model V2RenderInputPayload {
  ref               String
  workspaceId       String
  inputHash         String
  canonicalByteSize Int
  algorithm         String
  keyId             String
  nonce             String
  ciphertext        String
  authTag           String
  createdAt         DateTime @default(now())

  workspace V2Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  manifests V2MediaArtifactManifest[]

  @@id([workspaceId, ref])
  @@unique([workspaceId, inputHash])
  @@index([workspaceId, createdAt])
  @@map("v2_render_input_payloads")
}

model V2MediaArtifactLineage {
  id               String   @id
  workspaceId      String
  manifestId       String
  sourceArtifactId String
  role             String
  ordinal          Int
  toolId           String?
  toolVersion      String?
  toolDigest       String?
  modelProvider    String?
  modelId          String?
  modelVersion     String?
  modelConfigHash  String?
  createdAt        DateTime @default(now())

  workspace      V2Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  manifest       V2MediaArtifactManifest @relation(fields: [manifestId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  sourceArtifact V2MediaArtifact         @relation("V2MediaLineageSource", fields: [sourceArtifactId, workspaceId], references: [id, workspaceId], onDelete: Restrict)

  @@unique([manifestId, ordinal])
  @@unique([manifestId, sourceArtifactId, role])
  @@index([workspaceId, sourceArtifactId])
  @@map("v2_media_artifact_lineage")
}

model V2AssetRightsSnapshot {
  id                             String    @id
  workspaceId                    String
  artifactId                     String
  sequence                       Int
  schemaVersion                  String
  snapshotHash                   String
  owner                          String?
  license                        String?
  status                         String
  allowedUsesJson                String
  prohibitedUsesJson             String
  allowedWorkspaceIdsJson        String
  allowedMarketsJson             String?
  allowedLocalesJson             String?
  allowedSyntheticOperationsJson String?
  expiresAt                      DateTime?
  consentStatus                  String
  consentAllowedUsesJson         String
  consentAllowedMarketsJson      String?
  consentAllowedLocalesJson      String?
  consentSyntheticOperationsJson String?
  consentExpiresAt               DateTime?
  consentDocumentArtifactId      String?
  sourceNote                     String?
  createdByType                  String
  createdById                    String
  createdAt                      DateTime  @default(now())

  workspace           V2Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  artifact            V2MediaArtifact      @relation("V2AssetRightsSnapshots", fields: [artifactId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  currentForArtifacts V2MediaArtifact[]    @relation("V2CurrentAssetRights")
  consentDocument     V2MediaArtifact?     @relation("V2ConsentDocument", fields: [consentDocumentArtifactId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  decisions           V2AssetUseDecision[]

  @@unique([id, workspaceId])
  @@unique([artifactId, sequence])
  @@unique([artifactId, snapshotHash])
  @@index([workspaceId, status, expiresAt])
  @@index([workspaceId, consentStatus, consentExpiresAt])
  @@index([workspaceId, consentDocumentArtifactId])
  @@map("v2_asset_rights_snapshots")
}

model V2MaterializationAuthorization {
  id                 String    @id
  workspaceId        String
  artifactId         String
  manifestId         String
  inputHash          String
  rightsUse          String
  market             String?
  locale             String
  syntheticOpsJson   String
  status             String
  issuesJson         String
  clientId           String
  idempotencyKey     String
  requestFingerprint String
  evaluatedAt        DateTime
  validUntil         DateTime?
  createdAt          DateTime  @default(now())

  workspace        V2Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  targetArtifact   V2MediaArtifact             @relation("V2MaterializationTarget", fields: [artifactId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  manifest         V2MediaArtifactManifest     @relation(fields: [manifestId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  decisions        V2AssetUseDecision[]
  renderOperations V2ArtifactRenderOperation[]

  @@unique([id, workspaceId])
  @@unique([workspaceId, clientId, idempotencyKey])
  @@index([workspaceId, artifactId, evaluatedAt])
  @@index([workspaceId, status, validUntil])
  @@map("v2_materialization_authorizations")
}

model V2AssetUseDecision {
  id               String    @id
  workspaceId      String
  authorizationId  String
  artifactId       String
  assetOrdinal     Int
  assetKind        String
  rightsSnapshotId String?
  outcome          String
  reasonCodesJson  String
  evaluatedAt      DateTime
  validUntil       DateTime?
  createdAt        DateTime  @default(now())

  workspace      V2Workspace                    @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  authorization  V2MaterializationAuthorization @relation(fields: [authorizationId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  rightsSnapshot V2AssetRightsSnapshot?         @relation(fields: [rightsSnapshotId, workspaceId], references: [id, workspaceId], onDelete: Restrict)

  @@unique([authorizationId, assetOrdinal])
  @@index([workspaceId, artifactId, evaluatedAt])
  @@index([workspaceId, rightsSnapshotId])
  @@map("v2_asset_use_decisions")
}

model V2PublicOperation {
  id                 String    @id
  workspaceId        String
  clientId           String
  type               String
  status             String
  phase              String
  targetType         String
  targetId           String
  progressCompleted  Int?
  progressTotal      Int?
  progressUnit       String?
  cancelable         Boolean   @default(true)
  retryable          Boolean   @default(false)
  attempt            Int       @default(0)
  maxAttempts        Int       @default(3)
  resultJson         String?
  errorCode          String?
  errorMessage       String?
  errorRetryable     Boolean?
  idempotencyKey     String
  requestFingerprint String
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  startedAt          DateTime?
  completedAt        DateTime?
  leaseOwner         String?
  leaseExpiresAt     DateTime?
  heartbeatAt        DateTime?
  nextAttemptAt      DateTime?
  deadLetteredAt     DateTime?

  workspace      V2Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  client         V2ApiClient                @relation(fields: [clientId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  artifactRender V2ArtifactRenderOperation?

  @@unique([id, workspaceId])
  @@unique([workspaceId, clientId, idempotencyKey])
  @@index([workspaceId, createdAt, id])
  @@index([workspaceId, deadLetteredAt, createdAt, id])
  @@index([workspaceId, status, updatedAt])
  @@index([workspaceId, type, createdAt])
  @@index([workspaceId, targetType, targetId])
  @@index([status, leaseExpiresAt, createdAt])
  @@index([status, nextAttemptAt, createdAt])
  @@map("v2_public_operations")
}

model V2ArtifactRenderOperation {
  operationId            String    @id
  workspaceId            String
  artifactId             String
  manifestId             String
  authorizationId        String
  inputHash              String
  outputKey              String?
  outputSha256           String?
  outputByteSize         BigInt?
  outputWidth            Int?
  outputHeight           Int?
  outputFps              Float?
  outputDurationInFrames Int?
  outputCodec            String?
  outputContainer        String?
  outputAttempt          Int?
  outputCommittedAt      DateTime?
  outputRecordedAt       DateTime?

  workspace     V2Workspace                    @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  operation     V2PublicOperation              @relation(fields: [operationId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  artifact      V2MediaArtifact                @relation("V2ArtifactRenderTarget", fields: [artifactId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  manifest      V2MediaArtifactManifest        @relation(fields: [manifestId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  authorization V2MaterializationAuthorization @relation(fields: [authorizationId, workspaceId], references: [id, workspaceId], onDelete: Restrict)

  @@unique([operationId, workspaceId])
  @@index([workspaceId, artifactId, manifestId])
  @@index([workspaceId, authorizationId])
  @@map("v2_artifact_render_operations")
}

model V2PublicEventOutbox {
  id            String    @id
  workspaceId   String
  type          String
  version       String
  occurredAt    DateTime
  sequence      Int?
  actorClientId String?
  actorUserId   String?
  resourceType  String
  resourceId    String
  dataJson      String
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())

  workspace         V2Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  webhookDeliveries V2WebhookDelivery[]

  @@unique([id, workspaceId])
  @@index([publishedAt, occurredAt, id])
  @@index([workspaceId, publishedAt, occurredAt, id])
  @@index([workspaceId, occurredAt, id])
  @@index([workspaceId, resourceType, resourceId, occurredAt])
  @@map("v2_public_event_outbox")
}

model V2WebhookEndpoint {
  id                String    @id
  workspaceId       String
  url               String
  status            String    @default("pending-verification")
  createdByClientId String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  verifiedAt        DateTime?
  suspendedAt       DateTime?
  revokedAt         DateTime?

  workspace      V2Workspace                      @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  createdBy      V2ApiClient                      @relation("V2WebhookEndpointCreator", fields: [createdByClientId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  secrets        V2WebhookSigningSecret[]
  subscriptions  V2WebhookSubscription[]
  challenges     V2WebhookVerificationChallenge[]
  replayReceipts V2WebhookReplayReceipt[]

  @@unique([id, workspaceId])
  @@unique([workspaceId, url])
  @@index([workspaceId, status, createdAt])
  @@map("v2_webhook_endpoints")
}

model V2WebhookSigningSecret {
  id          String    @id
  workspaceId String
  endpointId  String
  version     Int
  algorithm   String    @default("hmac-sha256")
  keyRef      String    @unique
  fingerprint String
  status      String    @default("active")
  createdAt   DateTime  @default(now())
  retiredAt   DateTime?
  revokedAt   DateTime?

  workspace V2Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  endpoint  V2WebhookEndpoint @relation(fields: [endpointId, workspaceId], references: [id, workspaceId], onDelete: Restrict)

  @@unique([id, workspaceId])
  @@unique([endpointId, version])
  @@index([workspaceId, status, createdAt])
  @@map("v2_webhook_signing_secrets")
}

model V2WebhookSubscription {
  id                    String    @id
  workspaceId           String
  endpointId            String
  status                String    @default("pending-verification")
  filterEventTypesJson  String
  filterResourceIdsJson String?
  filterHash            String
  createdByClientId     String
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  pausedAt              DateTime?
  revokedAt             DateTime?

  workspace  V2Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  endpoint   V2WebhookEndpoint   @relation(fields: [endpointId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  createdBy  V2ApiClient         @relation("V2WebhookSubscriptionCreator", fields: [createdByClientId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  deliveries V2WebhookDelivery[]

  @@unique([id, workspaceId])
  @@unique([endpointId, filterHash])
  @@index([workspaceId, status, createdAt])
  @@map("v2_webhook_subscriptions")
}

model V2WebhookDelivery {
  id             String    @id
  workspaceId    String
  subscriptionId String
  eventId        String
  status         String    @default("pending")
  attemptCount   Int       @default(0)
  maxAttempts    Int       @default(8)
  nextAttemptAt  DateTime
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  completedAt    DateTime?
  deadLetteredAt DateTime?
  leaseOwner     String?
  leaseTokenHash String?
  leaseExpiresAt DateTime?
  heartbeatAt    DateTime?

  workspace    V2Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  subscription V2WebhookSubscription      @relation(fields: [subscriptionId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  event        V2PublicEventOutbox        @relation(fields: [eventId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  attempts     V2WebhookDeliveryAttempt[]

  @@unique([id, workspaceId])
  @@unique([subscriptionId, eventId])
  @@index([status, nextAttemptAt, createdAt])
  @@index([status, leaseExpiresAt, createdAt])
  @@index([workspaceId, status, createdAt])
  @@index([workspaceId, status, nextAttemptAt, id])
  @@index([workspaceId, status, leaseExpiresAt, id])
  @@map("v2_webhook_deliveries")
}

model V2WebhookDeliveryAttempt {
  id               String    @id
  workspaceId      String
  deliveryId       String
  attemptNumber    Int
  status           String    @default("scheduled")
  scheduledAt      DateTime
  startedAt        DateTime?
  completedAt      DateTime?
  responseStatus   Int?
  responseBodyHash String?
  errorCode        String?
  createdAt        DateTime  @default(now())

  workspace V2Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  delivery  V2WebhookDelivery @relation(fields: [deliveryId, workspaceId], references: [id, workspaceId], onDelete: Cascade)

  @@unique([id, workspaceId])
  @@unique([deliveryId, attemptNumber])
  @@index([workspaceId, status, scheduledAt])
  @@map("v2_webhook_delivery_attempts")
}

model V2WebhookVerificationChallenge {
  id           String    @id
  workspaceId  String
  endpointId   String
  tokenHash    String    @unique
  status       String    @default("pending")
  attemptCount Int       @default(0)
  maxAttempts  Int       @default(5)
  expiresAt    DateTime
  createdAt    DateTime  @default(now())
  verifiedAt   DateTime?
  failedAt     DateTime?

  workspace V2Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  endpoint  V2WebhookEndpoint @relation(fields: [endpointId, workspaceId], references: [id, workspaceId], onDelete: Cascade)

  @@unique([id, workspaceId])
  @@index([endpointId, status, createdAt])
  @@index([status, expiresAt])
  @@map("v2_webhook_verification_challenges")
}

model V2WebhookReplayReceipt {
  id                 String   @id
  workspaceId        String
  endpointId         String
  eventId            String
  signatureTimestamp DateTime
  receivedAt         DateTime
  expiresAt          DateTime

  workspace V2Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  endpoint  V2WebhookEndpoint @relation(fields: [endpointId, workspaceId], references: [id, workspaceId], onDelete: Cascade)

  @@unique([id, workspaceId])
  @@unique([endpointId, eventId])
  @@index([workspaceId, expiresAt])
  @@map("v2_webhook_replay_receipts")
}
