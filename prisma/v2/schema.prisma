generator client {
  provider      = "prisma-client-js"
  output        = "../../generated/prisma-v2"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("V2_DATABASE_URL")
}

model V2Workspace {
  id        String   @id @db.VarChar(128)
  slug      String   @unique @db.VarChar(63)
  name      String   @db.VarChar(120)
  status    String   @default("active") @db.VarChar(32)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  projects                        V2Project[]
  snapshots                       V2ProjectSnapshot[]
  apiClients                      V2ApiClient[]
  idempotencyRecords              V2IdempotencyRecord[]
  mediaArtifacts                  V2MediaArtifact[]
  mediaUploads                    V2MediaUpload[]
  projectMediaAssets              V2ProjectMediaAsset[]
  mediaTranscripts                V2MediaTranscript[]
  mediaIngestOperations           V2MediaIngestOperation[]
  projectProxyRenderOperations    V2ProjectProxyRenderOperation[]
  projectFinalExportOperations    V2ProjectFinalExportOperation[]
  mediaDownloadGrants             V2MediaDownloadGrant[]
  mediaManifests                  V2MediaArtifactManifest[]
  mediaLineage                    V2MediaArtifactLineage[]
  recipeParameters                V2RecipeParameterPayload[]
  renderInputs                    V2RenderInputPayload[]
  rightsSnapshots                 V2AssetRightsSnapshot[]
  materializations                V2MaterializationAuthorization[]
  assetUseDecisions               V2AssetUseDecision[]
  publicOperations                V2PublicOperation[]
  renderOperations                V2ArtifactRenderOperation[]
  publicEventOutbox               V2PublicEventOutbox[]
  webhookEndpoints                V2WebhookEndpoint[]
  webhookSecrets                  V2WebhookSigningSecret[]
  webhookSubscriptions            V2WebhookSubscription[]
  webhookSigningSecretPayloads    V2WebhookSigningSecretPayload[]
  webhookSigningSecretRotations   V2WebhookSigningSecretRotation[]
  webhookDeliveries               V2WebhookDelivery[]
  webhookAttempts                 V2WebhookDeliveryAttempt[]
  webhookChallenges               V2WebhookVerificationChallenge[]
  webhookEndpointActivationLeases V2WebhookEndpointActivationLease[]
  webhookReplayReceipts           V2WebhookReplayReceipt[]
  editCommands                    V2EditCommand[]
  directorRuns                    V2DirectorRun[]
  reviewAnnotations               V2ReviewAnnotation[]
  renderElementMaps               V2RenderElementMap[]
  reviewPatchProposals            V2ReviewPatchProposal[]

  @@map("workspaces")
}

model V2ApiClient {
  id          String    @id @db.VarChar(80)
  workspaceId String    @db.VarChar(128)
  name        String    @db.VarChar(120)
  status      String    @default("active") @db.VarChar(32)
  environment String    @default("sandbox") @db.VarChar(32)
  scopesJson  String    @db.Text
  secretSalt  String    @db.VarChar(128)
  secretHash  String    @db.VarChar(128)
  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(3)
  lastUsedAt  DateTime? @db.Timestamptz(3)

  workspace                   V2Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  credentials                 V2ApiCredential[]
  operations                  V2PublicOperation[]
  mediaUploads                V2MediaUpload[]
  mediaDownloadGrants         V2MediaDownloadGrant[]
  createdWebhookEndpoints     V2WebhookEndpoint[]     @relation("WebhookEndpointCreator")
  createdWebhookSubscriptions V2WebhookSubscription[] @relation("WebhookSubscriptionCreator")

  @@unique([id, workspaceId])
  @@index([workspaceId, status])
  @@map("api_clients")
}

model V2ApiCredential {
  id          String    @id @db.VarChar(80)
  workspaceId String    @db.VarChar(128)
  clientId    String    @db.VarChar(80)
  status      String    @default("active") @db.VarChar(32)
  secretSalt  String    @db.VarChar(128)
  secretHash  String    @db.VarChar(128)
  expiresAt   DateTime? @db.Timestamptz(3)
  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  lastUsedAt  DateTime? @db.Timestamptz(3)
  revokedAt   DateTime? @db.Timestamptz(3)

  client V2ApiClient @relation(fields: [clientId, workspaceId], references: [id, workspaceId], onDelete: Cascade)

  @@unique([id, clientId])
  @@index([clientId, status])
  @@index([workspaceId, status])
  @@index([expiresAt])
  @@map("api_credentials")
}

model V2MediaUpload {
  id                 String    @id @db.Uuid
  workspaceId        String    @db.VarChar(128)
  clientId           String    @db.VarChar(80)
  projectId          String?   @db.VarChar(128)
  fileName           String?   @db.VarChar(240)
  rightsConfirmed    Boolean   @default(false)
  kind               String    @db.VarChar(16)
  byteSize           BigInt
  mimeType           String    @db.VarChar(160)
  expectedSha256     String    @db.Char(64)
  status             String    @default("pending-session") @db.VarChar(32)
  idempotencyKey     String    @db.VarChar(128)
  requestFingerprint String    @db.Char(64)
  sessionMode        String?   @db.VarChar(16)
  partSize           BigInt?
  sessionExpiresAt   DateTime? @db.Timestamptz(3)
  actualSha256       String?   @db.Char(64)
  actualByteSize     BigInt?
  verifiedAt         DateTime? @db.Timestamptz(3)
  expiresAt          DateTime  @db.Timestamptz(3)
  createdAt          DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime  @updatedAt @db.Timestamptz(3)

  workspace       V2Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  client          V2ApiClient             @relation(fields: [clientId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  project         V2Project?              @relation(fields: [projectId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  parts           V2MediaUploadPart[]
  projectAssets   V2ProjectMediaAsset[]
  ingestOperation V2MediaIngestOperation?

  @@unique([id, workspaceId])
  @@unique([workspaceId, clientId, idempotencyKey])
  @@index([workspaceId, status, createdAt(sort: Desc)])
  @@index([workspaceId, status, expiresAt])
  @@index([workspaceId, projectId, createdAt(sort: Desc)])
  @@map("media_uploads")
}

model V2MediaUploadPart {
  id          String   @id @db.Uuid
  workspaceId String   @db.VarChar(128)
  uploadId    String   @db.Uuid
  partNumber  Int
  byteSize    BigInt
  etag        String   @db.VarChar(258)
  checksum    String   @db.Char(64)
  recordedAt  DateTime @db.Timestamptz(3)

  upload V2MediaUpload @relation(fields: [uploadId, workspaceId], references: [id, workspaceId], onDelete: Cascade)

  @@unique([uploadId, partNumber])
  @@index([workspaceId, uploadId, partNumber])
  @@map("media_upload_parts")
}

model V2Project {
  id               String   @id @db.VarChar(128)
  workspaceId      String   @db.VarChar(128)
  name             String   @db.VarChar(120)
  status           String   @default("draft") @db.VarChar(32)
  objective        String?  @db.VarChar(64)
  format           String?  @db.VarChar(16)
  locale           String?  @db.VarChar(35)
  ownerId          String?  @db.VarChar(128)
  currentVersionId String?  @db.VarChar(128)
  createdByType    String   @db.VarChar(32)
  createdById      String   @db.VarChar(128)
  createdAt        DateTime @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime @updatedAt @db.Timestamptz(3)

  workspace             V2Workspace                     @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  versions              V2ProjectVersion[]              @relation("ProjectVersions")
  snapshots             V2ProjectSnapshot[]
  currentVersion        V2ProjectVersion?               @relation("CurrentProjectVersion", fields: [currentVersionId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  mediaUploads          V2MediaUpload[]
  mediaAssets           V2ProjectMediaAsset[]
  mediaTranscripts      V2MediaTranscript[]
  mediaIngestOperations V2MediaIngestOperation[]
  proxyRenderOperations V2ProjectProxyRenderOperation[]
  finalExportOperations V2ProjectFinalExportOperation[]
  editCommands          V2EditCommand[]
  directorRuns          V2DirectorRun[]
  reviewAnnotations     V2ReviewAnnotation[]
  renderElementMaps     V2RenderElementMap[]
  reviewPatchProposals  V2ReviewPatchProposal[]

  @@unique([id, workspaceId])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([workspaceId, status])
  @@index([workspaceId, objective])
  @@index([workspaceId, format])
  @@index([workspaceId, locale])
  @@index([workspaceId, ownerId])
  @@map("projects")
}

model V2ProjectSnapshot {
  id            String   @id @db.VarChar(128)
  workspaceId   String   @db.VarChar(128)
  projectId     String   @db.VarChar(128)
  kind          String   @db.VarChar(32)
  schemaVersion Int
  contentJson   String   @db.Text
  contentHash   String   @db.Char(64)
  createdAt     DateTime @default(now()) @db.Timestamptz(3)

  workspace              V2Workspace                     @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  project                V2Project                       @relation(fields: [projectId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  briefVersions          V2ProjectVersion[]              @relation("BriefSnapshot")
  treatmentVersions      V2ProjectVersion[]              @relation("TreatmentSnapshot")
  storyVersions          V2ProjectVersion[]              @relation("StorySnapshot")
  editPlanVersions       V2ProjectVersion[]              @relation("EditPlanSnapshot")
  policyVersions         V2ProjectVersion[]              @relation("PoliciesSnapshot")
  perceptionDirectorRuns V2DirectorRun[]                 @relation("DirectorRunPerceptionSnapshot")
  treatmentDirectorRuns  V2DirectorRun[]                 @relation("DirectorRunTreatmentSnapshot")
  storyDirectorRuns      V2DirectorRun[]                 @relation("DirectorRunStorySnapshot")
  editPlanDirectorRuns   V2DirectorRun[]                 @relation("DirectorRunEditPlanSnapshot")
  qualityDirectorRuns    V2DirectorRun[]                 @relation("DirectorRunQualitySnapshot")
  finalExportOperations  V2ProjectFinalExportOperation[] @relation("FinalExportQualitySnapshot")

  @@unique([projectId, kind, contentHash])
  @@index([workspaceId, kind])
  @@map("project_snapshots")
}

model V2ProjectVersion {
  id                  String   @id @db.VarChar(128)
  workspaceId         String   @db.VarChar(128)
  projectId           String   @db.VarChar(128)
  sequence            Int
  parentVersionId     String?  @db.VarChar(128)
  briefSnapshotId     String   @db.VarChar(128)
  treatmentSnapshotId String?  @db.VarChar(128)
  storySnapshotId     String?  @db.VarChar(128)
  editPlanSnapshotId  String   @db.VarChar(128)
  policiesSnapshotId  String   @db.VarChar(128)
  baseHash            String   @db.Char(64)
  createdBy           String   @db.VarChar(128)
  commandId           String?  @db.VarChar(128)
  createdAt           DateTime @default(now()) @db.Timestamptz(3)

  project               V2Project                       @relation("ProjectVersions", fields: [projectId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  currentForProjects    V2Project[]                     @relation("CurrentProjectVersion")
  parent                V2ProjectVersion?               @relation("VersionParent", fields: [parentVersionId], references: [id], onDelete: SetNull)
  children              V2ProjectVersion[]              @relation("VersionParent")
  briefSnapshot         V2ProjectSnapshot               @relation("BriefSnapshot", fields: [briefSnapshotId], references: [id], onDelete: Restrict)
  treatmentSnapshot     V2ProjectSnapshot?              @relation("TreatmentSnapshot", fields: [treatmentSnapshotId], references: [id], onDelete: Restrict)
  storySnapshot         V2ProjectSnapshot?              @relation("StorySnapshot", fields: [storySnapshotId], references: [id], onDelete: Restrict)
  editPlanSnapshot      V2ProjectSnapshot               @relation("EditPlanSnapshot", fields: [editPlanSnapshotId], references: [id], onDelete: Restrict)
  policiesSnapshot      V2ProjectSnapshot               @relation("PoliciesSnapshot", fields: [policiesSnapshotId], references: [id], onDelete: Restrict)
  command               V2EditCommand?                  @relation("CommandResultVersion", fields: [commandId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  commandsBasedOn       V2EditCommand[]                 @relation("CommandBaseVersion")
  proxyRenderOperations V2ProjectProxyRenderOperation[]
  finalExportOperations V2ProjectFinalExportOperation[]
  directorRunsAsBase    V2DirectorRun[]                 @relation("DirectorRunBaseVersion")
  directorRunAsResult   V2DirectorRun?                  @relation("DirectorRunResultVersion")
  reviewAnnotations     V2ReviewAnnotation[]
  renderElementMaps     V2RenderElementMap[]
  patchProposalsAsBase  V2ReviewPatchProposal[]         @relation("PatchProposalBaseVersion")
  patchProposalAsResult V2ReviewPatchProposal?          @relation("PatchProposalResultVersion")

  @@unique([projectId, sequence])
  @@unique([id, workspaceId])
  @@unique([commandId, workspaceId])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@map("project_versions")
}

model V2EditCommand {
  id                 String   @id @db.VarChar(128)
  workspaceId        String   @db.VarChar(128)
  projectId          String   @db.VarChar(128)
  baseVersionId      String   @db.VarChar(128)
  baseHash           String   @db.Char(64)
  type               String   @db.VarChar(80)
  scopeJson          String   @db.Text
  payloadJson        String   @db.Text
  reason             String?  @db.VarChar(1000)
  actorType          String   @db.VarChar(32)
  actorId            String   @db.VarChar(128)
  delegatedUserId    String?  @db.VarChar(128)
  idempotencyKey     String   @db.VarChar(128)
  requestFingerprint String   @db.Char(64)
  createdAt          DateTime @db.Timestamptz(3)

  workspace     V2Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  project       V2Project         @relation(fields: [projectId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  baseVersion   V2ProjectVersion  @relation("CommandBaseVersion", fields: [baseVersionId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  resultVersion V2ProjectVersion? @relation("CommandResultVersion")
  directorRun   V2DirectorRun?    @relation("DirectorRunCommand")

  @@unique([id, workspaceId])
  @@unique([workspaceId, projectId, idempotencyKey])
  @@index([workspaceId, projectId, createdAt(sort: Desc)])
  @@index([workspaceId, baseVersionId])
  @@map("edit_commands")
}

model V2ReviewAnnotation {
  id                   String   @id @db.Uuid
  workspaceId          String   @db.VarChar(128)
  projectId            String   @db.VarChar(128)
  projectVersionId     String   @db.VarChar(128)
  proxyArtifactId      String   @db.VarChar(128)
  proxyHash            String   @db.Char(64)
  frame                Int
  timeStartMs          Int
  timeEndMs            Int
  scope                String   @db.VarChar(16)
  regionX              Float?
  regionY              Float?
  regionWidth          Float?
  regionHeight         Float?
  targetIdsJson        String   @db.Text
  applicationScopeJson String   @db.Text
  affectedCount        Int
  screenshotRef        String   @db.Text
  text                 String   @db.Text
  authorType           String   @db.VarChar(32)
  authorId             String   @db.VarChar(128)
  authorName           String   @db.VarChar(120)
  status               String   @default("open") @db.VarChar(16)
  idempotencyKey       String   @db.VarChar(128)
  requestFingerprint   String   @db.Char(64)
  createdAt            DateTime @default(now()) @db.Timestamptz(3)
  updatedAt            DateTime @updatedAt @db.Timestamptz(3)

  workspace      V2Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  project        V2Project               @relation(fields: [projectId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  projectVersion V2ProjectVersion        @relation(fields: [projectVersionId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  proxyArtifact  V2MediaArtifact         @relation(fields: [proxyArtifactId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  patchProposals V2ReviewPatchProposal[]

  @@unique([id, workspaceId])
  @@unique([workspaceId, projectId, idempotencyKey])
  @@index([workspaceId, projectId, createdAt(sort: Desc)])
  @@index([workspaceId, projectVersionId, status])
  @@index([workspaceId, proxyArtifactId])
  @@map("review_annotations")
}

model V2ReviewPatchProposal {
  id                      String    @id @db.Uuid
  workspaceId             String    @db.VarChar(128)
  projectId               String    @db.VarChar(128)
  annotationId            String    @db.Uuid
  baseVersionId           String    @db.VarChar(128)
  status                  String    @db.VarChar(32)
  interpretationVersion   String    @db.VarChar(128)
  choicesJson             String    @db.Text
  patchJson               String?   @db.Text
  impactJson              String?   @db.Text
  gatesJson               String    @db.Text
  idempotencyKey          String    @db.VarChar(128)
  requestFingerprint      String    @db.Char(64)
  applyIdempotencyKey     String?   @db.VarChar(128)
  applyRequestFingerprint String?   @db.Char(64)
  resultCommandId         String?   @db.VarChar(128)
  resultVersionId         String?   @db.VarChar(128)
  renderOperationId       String?   @db.VarChar(128)
  comparisonJson          String?   @db.Text
  createdAt               DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt               DateTime  @updatedAt @db.Timestamptz(3)
  appliedAt               DateTime? @db.Timestamptz(3)

  workspace       V2Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  project         V2Project          @relation(fields: [projectId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  annotation      V2ReviewAnnotation @relation(fields: [annotationId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  baseVersion     V2ProjectVersion   @relation("PatchProposalBaseVersion", fields: [baseVersionId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  resultVersion   V2ProjectVersion?  @relation("PatchProposalResultVersion", fields: [resultVersionId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  renderOperation V2PublicOperation? @relation(fields: [renderOperationId, workspaceId], references: [id, workspaceId], onDelete: Restrict)

  @@unique([id, workspaceId])
  @@unique([workspaceId, projectId, idempotencyKey])
  @@unique([resultVersionId, workspaceId])
  @@unique([renderOperationId, workspaceId])
  @@index([workspaceId, projectId, annotationId, createdAt(sort: Desc)])
  @@index([workspaceId, baseVersionId, status])
  @@map("review_patch_proposals")
}

model V2RenderElementMap {
  id               String   @id @db.Uuid
  workspaceId      String   @db.VarChar(128)
  projectId        String   @db.VarChar(128)
  projectVersionId String   @db.VarChar(128)
  proxyArtifactId  String   @db.VarChar(128)
  proxyHash        String   @db.Char(64)
  mapHash          String   @db.Char(64)
  schemaVersion    String   @db.VarChar(64)
  fps              Float
  durationFrames   Int
  canvasWidth      Int
  canvasHeight     Int
  elementsJson     String   @db.Text
  createdAt        DateTime @default(now()) @db.Timestamptz(3)

  workspace      V2Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  project        V2Project        @relation(fields: [projectId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  projectVersion V2ProjectVersion @relation(fields: [projectVersionId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  proxyArtifact  V2MediaArtifact  @relation(fields: [proxyArtifactId, workspaceId], references: [id, workspaceId], onDelete: Restrict)

  @@unique([workspaceId, projectVersionId, proxyArtifactId])
  @@index([workspaceId, projectId, createdAt(sort: Desc)])
  @@index([workspaceId, proxyArtifactId, proxyHash])
  @@map("render_element_maps")
}

model V2DirectorRun {
  id                   String   @id @db.VarChar(128)
  workspaceId          String   @db.VarChar(128)
  projectId            String   @db.VarChar(128)
  commandId            String   @db.VarChar(128)
  baseVersionId        String   @db.VarChar(128)
  resultVersionId      String   @db.VarChar(128)
  status               String   @db.VarChar(32)
  plannerVersion       String   @db.VarChar(64)
  criticVersion        String   @db.VarChar(64)
  perceptionSnapshotId String   @db.VarChar(128)
  treatmentSnapshotId  String   @db.VarChar(128)
  storySnapshotId      String   @db.VarChar(128)
  editPlanSnapshotId   String   @db.VarChar(128)
  qualitySnapshotId    String   @db.VarChar(128)
  decisionsJson        String   @db.Text
  assumptionsJson      String   @db.Text
  initiatedByType      String   @db.VarChar(32)
  initiatedById        String   @db.VarChar(128)
  createdAt            DateTime @default(now()) @db.Timestamptz(3)
  updatedAt            DateTime @updatedAt @db.Timestamptz(3)

  workspace             V2Workspace                     @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  project               V2Project                       @relation(fields: [projectId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  command               V2EditCommand                   @relation("DirectorRunCommand", fields: [commandId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  baseVersion           V2ProjectVersion                @relation("DirectorRunBaseVersion", fields: [baseVersionId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  resultVersion         V2ProjectVersion                @relation("DirectorRunResultVersion", fields: [resultVersionId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  perceptionSnapshot    V2ProjectSnapshot               @relation("DirectorRunPerceptionSnapshot", fields: [perceptionSnapshotId], references: [id], onDelete: Restrict)
  treatmentSnapshot     V2ProjectSnapshot               @relation("DirectorRunTreatmentSnapshot", fields: [treatmentSnapshotId], references: [id], onDelete: Restrict)
  storySnapshot         V2ProjectSnapshot               @relation("DirectorRunStorySnapshot", fields: [storySnapshotId], references: [id], onDelete: Restrict)
  editPlanSnapshot      V2ProjectSnapshot               @relation("DirectorRunEditPlanSnapshot", fields: [editPlanSnapshotId], references: [id], onDelete: Restrict)
  qualitySnapshot       V2ProjectSnapshot               @relation("DirectorRunQualitySnapshot", fields: [qualitySnapshotId], references: [id], onDelete: Restrict)
  finalExportOperations V2ProjectFinalExportOperation[]

  @@unique([id, workspaceId])
  @@unique([commandId, workspaceId])
  @@unique([resultVersionId, workspaceId])
  @@index([workspaceId, projectId, createdAt(sort: Desc)])
  @@index([workspaceId, status, updatedAt(sort: Desc)])
  @@map("director_runs")
}

model V2IdempotencyRecord {
  id                 String   @id @db.VarChar(128)
  workspaceId        String   @db.VarChar(128)
  clientId           String   @db.VarChar(80)
  key                String   @db.VarChar(128)
  requestFingerprint String   @db.Char(64)
  status             String   @db.VarChar(32)
  responseStatus     Int?
  responseJson       String?  @db.Text
  expiresAt          DateTime @db.Timestamptz(3)
  createdAt          DateTime @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime @updatedAt @db.Timestamptz(3)

  workspace V2Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, clientId, key])
  @@index([expiresAt])
  @@map("idempotency_records")
}

model V2MediaArtifact {
  id                      String   @id @db.VarChar(128)
  workspaceId             String   @db.VarChar(128)
  artifactKey             String   @db.VarChar(512)
  sha256                  String   @db.Char(64)
  byteSize                BigInt
  mediaType               String   @db.VarChar(16)
  container               String   @db.VarChar(32)
  status                  String   @default("available") @db.VarChar(32)
  currentRightsSnapshotId String?  @db.VarChar(128)
  rightsRevision          Int      @default(0)
  createdAt               DateTime @default(now()) @db.Timestamptz(3)

  workspace              V2Workspace                      @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  manifests              V2MediaArtifactManifest[]
  lineageUses            V2MediaArtifactLineage[]         @relation("MediaLineageSource")
  rightsSnapshots        V2AssetRightsSnapshot[]          @relation("AssetRightsSnapshots")
  currentRightsSnapshot  V2AssetRightsSnapshot?           @relation("CurrentAssetRights", fields: [currentRightsSnapshotId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  consentEvidenceFor     V2AssetRightsSnapshot[]          @relation("ConsentDocument")
  materializationTargets V2MaterializationAuthorization[] @relation("MaterializationTarget")
  renderOperationTargets V2ArtifactRenderOperation[]      @relation("ArtifactRenderTarget")
  downloadGrants         V2MediaDownloadGrant[]
  projectAssets          V2ProjectMediaAsset[]
  transcriptSources      V2MediaTranscript[]
  reviewAnnotations      V2ReviewAnnotation[]
  renderElementMaps      V2RenderElementMap[]

  @@unique([id, workspaceId])
  @@unique([workspaceId, artifactKey])
  @@index([workspaceId, sha256])
  @@index([workspaceId, mediaType, status])
  @@index([workspaceId, currentRightsSnapshotId])
  @@map("media_artifacts")
}

model V2MediaDownloadGrant {
  id                 String    @id @db.Uuid
  workspaceId        String    @db.VarChar(128)
  clientId           String    @db.VarChar(80)
  artifactId         String    @db.VarChar(128)
  tokenHash          String    @db.Char(64)
  idempotencyKey     String    @db.VarChar(128)
  requestFingerprint String    @db.Char(64)
  status             String    @default("active") @db.VarChar(16)
  expiresAt          DateTime  @db.Timestamptz(3)
