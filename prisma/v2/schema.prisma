generator client {
  provider = "prisma-client-js"
  output   = "../../generated/prisma-v2"
}

datasource db {
  provider = "postgresql"
  url      = env("V2_DATABASE_URL")
}

model V2Workspace {
  id        String   @id @db.VarChar(128)
  slug      String   @unique @db.VarChar(63)
  name      String   @db.VarChar(120)
  status    String   @default("active") @db.VarChar(32)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  projects              V2Project[]
  snapshots             V2ProjectSnapshot[]
  apiClients            V2ApiClient[]
  idempotencyRecords    V2IdempotencyRecord[]
  mediaArtifacts        V2MediaArtifact[]
  mediaManifests        V2MediaArtifactManifest[]
  mediaLineage          V2MediaArtifactLineage[]
  recipeParameters      V2RecipeParameterPayload[]
  renderInputs          V2RenderInputPayload[]
  rightsSnapshots       V2AssetRightsSnapshot[]
  materializations      V2MaterializationAuthorization[]
  assetUseDecisions     V2AssetUseDecision[]
  publicOperations      V2PublicOperation[]
  renderOperations      V2ArtifactRenderOperation[]
  publicEventOutbox     V2PublicEventOutbox[]
  webhookEndpoints      V2WebhookEndpoint[]
  webhookSecrets        V2WebhookSigningSecret[]
  webhookSubscriptions  V2WebhookSubscription[]
  webhookSigningSecretPayloads V2WebhookSigningSecretPayload[]
  webhookSigningSecretRotations V2WebhookSigningSecretRotation[]
  webhookDeliveries     V2WebhookDelivery[]
  webhookAttempts       V2WebhookDeliveryAttempt[]
  webhookChallenges     V2WebhookVerificationChallenge[]
  webhookReplayReceipts V2WebhookReplayReceipt[]

  @@map("workspaces")
}

model V2ApiClient {
  id          String    @id @db.VarChar(80)
  workspaceId String    @db.VarChar(128)
  name        String    @db.VarChar(120)
  status      String    @default("active") @db.VarChar(32)
  environment String    @default("sandbox") @db.VarChar(32)
  scopesJson  String    @db.Text
  secretSalt  String    @db.VarChar(128)
  secretHash  String    @db.VarChar(128)
  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(3)
  lastUsedAt  DateTime? @db.Timestamptz(3)

  workspace                   V2Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  credentials                 V2ApiCredential[]
  operations                  V2PublicOperation[]
  createdWebhookEndpoints     V2WebhookEndpoint[]     @relation("WebhookEndpointCreator")
  createdWebhookSubscriptions V2WebhookSubscription[] @relation("WebhookSubscriptionCreator")

  @@unique([id, workspaceId])
  @@index([workspaceId, status])
  @@map("api_clients")
}

model V2ApiCredential {
  id          String    @id @db.VarChar(80)
  workspaceId String    @db.VarChar(128)
  clientId    String    @db.VarChar(80)
  status      String    @default("active") @db.VarChar(32)
  secretSalt  String    @db.VarChar(128)
  secretHash  String    @db.VarChar(128)
  expiresAt   DateTime? @db.Timestamptz(3)
  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  lastUsedAt  DateTime? @db.Timestamptz(3)
  revokedAt   DateTime? @db.Timestamptz(3)

  client V2ApiClient @relation(fields: [clientId, workspaceId], references: [id, workspaceId], onDelete: Cascade)

  @@unique([id, clientId])
  @@index([clientId, status])
  @@index([workspaceId, status])
  @@index([expiresAt])
  @@map("api_credentials")
}

model V2Project {
  id               String   @id @db.VarChar(128)
  workspaceId      String   @db.VarChar(128)
  name             String   @db.VarChar(120)
  status           String   @default("draft") @db.VarChar(32)
  currentVersionId String?  @db.VarChar(128)
  createdByType    String   @db.VarChar(32)
  createdById      String   @db.VarChar(128)
  createdAt        DateTime @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime @updatedAt @db.Timestamptz(3)

  workspace      V2Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  versions       V2ProjectVersion[]  @relation("ProjectVersions")
  snapshots      V2ProjectSnapshot[]
  currentVersion V2ProjectVersion?   @relation("CurrentProjectVersion", fields: [currentVersionId, workspaceId], references: [id, workspaceId], onDelete: Restrict)

  @@unique([id, workspaceId])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([workspaceId, status])
  @@map("projects")
}

model V2ProjectSnapshot {
  id            String   @id @db.VarChar(128)
  workspaceId   String   @db.VarChar(128)
  projectId     String   @db.VarChar(128)
  kind          String   @db.VarChar(32)
  schemaVersion Int
  contentJson   String   @db.Text
  contentHash   String   @db.Char(64)
  createdAt     DateTime @default(now()) @db.Timestamptz(3)

  workspace        V2Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  project          V2Project          @relation(fields: [projectId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  editPlanVersions V2ProjectVersion[] @relation("EditPlanSnapshot")
  policyVersions   V2ProjectVersion[] @relation("PoliciesSnapshot")

  @@unique([projectId, kind, contentHash])
  @@index([workspaceId, kind])
  @@map("project_snapshots")
}

model V2ProjectVersion {
  id                 String   @id @db.VarChar(128)
  workspaceId        String   @db.VarChar(128)
  projectId          String   @db.VarChar(128)
  sequence           Int
  parentVersionId    String?  @db.VarChar(128)
  editPlanSnapshotId String   @db.VarChar(128)
  policiesSnapshotId String   @db.VarChar(128)
  baseHash           String   @db.Char(64)
  createdBy          String   @db.VarChar(128)
  commandId          String?  @db.VarChar(128)
  createdAt          DateTime @default(now()) @db.Timestamptz(3)

  project            V2Project          @relation("ProjectVersions", fields: [projectId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  currentForProjects V2Project[]        @relation("CurrentProjectVersion")
  parent             V2ProjectVersion?  @relation("VersionParent", fields: [parentVersionId], references: [id], onDelete: SetNull)
  children           V2ProjectVersion[] @relation("VersionParent")
  editPlanSnapshot   V2ProjectSnapshot  @relation("EditPlanSnapshot", fields: [editPlanSnapshotId], references: [id], onDelete: Restrict)
  policiesSnapshot   V2ProjectSnapshot  @relation("PoliciesSnapshot", fields: [policiesSnapshotId], references: [id], onDelete: Restrict)

  @@unique([projectId, sequence])
  @@unique([id, workspaceId])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@map("project_versions")
}

model V2IdempotencyRecord {
  id                 String   @id @db.VarChar(128)
  workspaceId        String   @db.VarChar(128)
  clientId           String   @db.VarChar(80)
  key                String   @db.VarChar(128)
  requestFingerprint String   @db.Char(64)
  status             String   @db.VarChar(32)
  responseStatus     Int?
  responseJson       String?  @db.Text
  expiresAt          DateTime @db.Timestamptz(3)
  createdAt          DateTime @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime @updatedAt @db.Timestamptz(3)

  workspace V2Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, clientId, key])
  @@index([expiresAt])
  @@map("idempotency_records")
}

model V2MediaArtifact {
  id                      String   @id @db.VarChar(128)
  workspaceId             String   @db.VarChar(128)
  artifactKey             String   @db.VarChar(512)
  sha256                  String   @db.Char(64)
  byteSize                BigInt
  mediaType               String   @db.VarChar(16)
  container               String   @db.VarChar(32)
  status                  String   @default("available") @db.VarChar(32)
  currentRightsSnapshotId String?  @db.VarChar(128)
  rightsRevision          Int      @default(0)
  createdAt               DateTime @default(now()) @db.Timestamptz(3)

  workspace              V2Workspace                      @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  manifests              V2MediaArtifactManifest[]
  lineageUses            V2MediaArtifactLineage[]         @relation("MediaLineageSource")
  rightsSnapshots        V2AssetRightsSnapshot[]          @relation("AssetRightsSnapshots")
  currentRightsSnapshot  V2AssetRightsSnapshot?           @relation("CurrentAssetRights", fields: [currentRightsSnapshotId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  consentEvidenceFor     V2AssetRightsSnapshot[]          @relation("ConsentDocument")
  materializationTargets V2MaterializationAuthorization[] @relation("MaterializationTarget")
  renderOperationTargets V2ArtifactRenderOperation[]      @relation("ArtifactRenderTarget")

  @@unique([id, workspaceId])
  @@unique([workspaceId, artifactKey])
  @@index([workspaceId, sha256])
  @@index([workspaceId, mediaType, status])
  @@index([workspaceId, currentRightsSnapshotId])
  @@map("media_artifacts")
}

model V2MediaArtifactManifest {
  id                  String   @id @db.VarChar(128)
  workspaceId         String   @db.VarChar(128)
  artifactId          String   @db.VarChar(128)
  schemaVersion       String   @db.VarChar(64)
  manifestHash        String   @db.Char(64)
  recipeId            String   @db.VarChar(64)
  recipeVersion       String   @db.VarChar(64)
  parametersHash      String   @db.Char(64)
  recipeParametersRef String?  @db.VarChar(128)
  renderInputRef      String?  @db.VarChar(128)
  renderInputHash     String?  @db.Char(64)
  manifestJson        String   @db.Text
  createdAt           DateTime @default(now()) @db.Timestamptz(3)

  workspace        V2Workspace                      @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  artifact         V2MediaArtifact                  @relation(fields: [artifactId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  lineageEdges     V2MediaArtifactLineage[]
  recipeParameters V2RecipeParameterPayload?        @relation(fields: [recipeParametersRef, workspaceId], references: [ref, workspaceId], onDelete: Restrict)
  renderInput      V2RenderInputPayload?            @relation(fields: [renderInputRef, workspaceId], references: [ref, workspaceId], onDelete: Restrict)
  materializations V2MaterializationAuthorization[]
  renderOperations V2ArtifactRenderOperation[]

  @@unique([id, workspaceId])
  @@unique([artifactId, manifestHash])
  @@index([workspaceId, recipeId, recipeVersion])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([workspaceId, recipeParametersRef])
  @@index([workspaceId, renderInputRef])
  @@map("media_artifact_manifests")
}

model V2RecipeParameterPayload {
  ref               String   @db.VarChar(128)
  workspaceId       String   @db.VarChar(128)
  parametersHash    String   @db.Char(64)
  canonicalByteSize Int
  algorithm         String   @db.VarChar(32)
  keyId             String   @db.VarChar(64)
  nonce             String   @db.VarChar(32)
  ciphertext        String   @db.Text
  authTag           String   @db.VarChar(32)
  createdAt         DateTime @default(now()) @db.Timestamptz(3)

  workspace V2Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  manifests V2MediaArtifactManifest[]

  @@id([workspaceId, ref])
  @@unique([workspaceId, parametersHash])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@map("recipe_parameter_payloads")
}

model V2RenderInputPayload {
  ref               String   @db.VarChar(128)
  workspaceId       String   @db.VarChar(128)
  inputHash         String   @db.Char(64)
  canonicalByteSize Int
  algorithm         String   @db.VarChar(32)
  keyId             String   @db.VarChar(64)
  nonce             String   @db.VarChar(32)
  ciphertext        String   @db.Text
  authTag           String   @db.VarChar(32)
  createdAt         DateTime @default(now()) @db.Timestamptz(3)

  workspace V2Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  manifests V2MediaArtifactManifest[]

  @@id([workspaceId, ref])
  @@unique([workspaceId, inputHash])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@map("render_input_payloads")
}

model V2MediaArtifactLineage {
  id               String   @id @db.VarChar(128)
  workspaceId      String   @db.VarChar(128)
  manifestId       String   @db.VarChar(128)
  sourceArtifactId String   @db.VarChar(128)
  role             String   @db.VarChar(64)
  ordinal          Int
  toolId           String?  @db.VarChar(64)
  toolVersion      String?  @db.VarChar(64)
  toolDigest       String?  @db.Char(64)
  modelProvider    String?  @db.VarChar(64)
  modelId          String?  @db.VarChar(128)
  modelVersion     String?  @db.VarChar(64)
  modelConfigHash  String?  @db.Char(64)
  createdAt        DateTime @default(now()) @db.Timestamptz(3)

  workspace      V2Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  manifest       V2MediaArtifactManifest @relation(fields: [manifestId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  sourceArtifact V2MediaArtifact         @relation("MediaLineageSource", fields: [sourceArtifactId, workspaceId], references: [id, workspaceId], onDelete: Restrict)

  @@unique([manifestId, ordinal])
  @@unique([manifestId, sourceArtifactId, role])
  @@index([workspaceId, sourceArtifactId])
  @@map("media_artifact_lineage")
}

model V2AssetRightsSnapshot {
  id                             String    @id @db.VarChar(128)
  workspaceId                    String    @db.VarChar(128)
  artifactId                     String    @db.VarChar(128)
  sequence                       Int
  schemaVersion                  String    @db.VarChar(64)
  snapshotHash                   String    @db.Char(64)
  owner                          String?   @db.VarChar(240)
  license                        String?   @db.VarChar(240)
  status                         String    @db.VarChar(32)
  allowedUsesJson                String    @db.Text
  prohibitedUsesJson             String    @db.Text
  allowedWorkspaceIdsJson        String    @db.Text
  allowedMarketsJson             String?   @db.Text
  allowedLocalesJson             String?   @db.Text
  allowedSyntheticOperationsJson String?   @db.Text
  expiresAt                      DateTime? @db.Timestamptz(3)
  consentStatus                  String    @db.VarChar(32)
  consentAllowedUsesJson         String    @db.Text
  consentAllowedMarketsJson      String?   @db.Text
  consentAllowedLocalesJson      String?   @db.Text
  consentSyntheticOperationsJson String?   @db.Text
  consentExpiresAt               DateTime? @db.Timestamptz(3)
  consentDocumentArtifactId      String?   @db.VarChar(128)
  sourceNote                     String?   @db.Text
  createdByType                  String    @db.VarChar(32)
  createdById                    String    @db.VarChar(128)
  createdAt                      DateTime  @default(now()) @db.Timestamptz(3)

  workspace           V2Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  artifact            V2MediaArtifact      @relation("AssetRightsSnapshots", fields: [artifactId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  currentForArtifacts V2MediaArtifact[]    @relation("CurrentAssetRights")
  consentDocument     V2MediaArtifact?     @relation("ConsentDocument", fields: [consentDocumentArtifactId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  decisions           V2AssetUseDecision[]

  @@unique([id, workspaceId])
  @@unique([artifactId, sequence])
  @@unique([artifactId, snapshotHash])
  @@index([workspaceId, status, expiresAt])
  @@index([workspaceId, consentStatus, consentExpiresAt])
  @@index([workspaceId, consentDocumentArtifactId])
  @@map("asset_rights_snapshots")
}

model V2MaterializationAuthorization {
  id                 String    @id @db.VarChar(128)
  workspaceId        String    @db.VarChar(128)
  artifactId         String    @db.VarChar(128)
  manifestId         String    @db.VarChar(128)
  inputHash          String    @db.Char(64)
  rightsUse          String    @db.VarChar(64)
  market             String?   @db.VarChar(16)
  locale             String    @db.VarChar(32)
  syntheticOpsJson   String    @db.Text
  status             String    @db.VarChar(32)
  issuesJson         String    @db.Text
  clientId           String    @db.VarChar(80)
  idempotencyKey     String    @db.VarChar(128)
  requestFingerprint String    @db.Char(64)
  evaluatedAt        DateTime  @db.Timestamptz(3)
  validUntil         DateTime? @db.Timestamptz(3)
  createdAt          DateTime  @default(now()) @db.Timestamptz(3)

  workspace        V2Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  targetArtifact   V2MediaArtifact             @relation("MaterializationTarget", fields: [artifactId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  manifest         V2MediaArtifactManifest     @relation(fields: [manifestId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  decisions        V2AssetUseDecision[]
  renderOperations V2ArtifactRenderOperation[]

  @@unique([id, workspaceId])
  @@unique([workspaceId, clientId, idempotencyKey])
  @@index([workspaceId, artifactId, evaluatedAt(sort: Desc)])
  @@index([workspaceId, status, validUntil])
  @@map("materialization_authorizations")
}

model V2AssetUseDecision {
  id               String    @id @db.VarChar(128)
  workspaceId      String    @db.VarChar(128)
  authorizationId  String    @db.VarChar(128)
  artifactId       String    @db.VarChar(128)
  assetOrdinal     Int
  assetKind        String    @db.VarChar(16)
  rightsSnapshotId String?   @db.VarChar(128)
  outcome          String    @db.VarChar(16)
  reasonCodesJson  String    @db.Text
  evaluatedAt      DateTime  @db.Timestamptz(3)
  validUntil       DateTime? @db.Timestamptz(3)
  createdAt        DateTime  @default(now()) @db.Timestamptz(3)

  workspace      V2Workspace                    @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  authorization  V2MaterializationAuthorization @relation(fields: [authorizationId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  rightsSnapshot V2AssetRightsSnapshot?         @relation(fields: [rightsSnapshotId, workspaceId], references: [id, workspaceId], onDelete: Restrict)

  @@unique([authorizationId, assetOrdinal])
  @@index([workspaceId, artifactId, evaluatedAt(sort: Desc)])
  @@index([workspaceId, rightsSnapshotId])
  @@map("asset_use_decisions")
}

model V2PublicOperation {
  id                 String    @id @db.VarChar(128)
  workspaceId        String    @db.VarChar(128)
  clientId           String    @db.VarChar(80)
  type               String    @db.VarChar(64)
  status             String    @db.VarChar(32)
  phase              String    @db.VarChar(64)
  targetType         String    @db.VarChar(64)
  targetId           String    @db.VarChar(128)
  progressCompleted  Int?
  progressTotal      Int?
  progressUnit       String?   @db.VarChar(64)
  cancelable         Boolean   @default(true)
  retryable          Boolean   @default(false)
  attempt            Int       @default(0)
  maxAttempts        Int       @default(3)
  resultJson         String?   @db.Text
  errorCode          String?   @db.VarChar(64)
  errorMessage       String?   @db.Text
  errorRetryable     Boolean?
  idempotencyKey     String    @db.VarChar(128)
  requestFingerprint String    @db.Char(64)
  createdAt          DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime  @updatedAt @db.Timestamptz(3)
  startedAt          DateTime? @db.Timestamptz(3)
  completedAt        DateTime? @db.Timestamptz(3)
  leaseOwner         String?   @db.VarChar(128)
  leaseExpiresAt     DateTime? @db.Timestamptz(3)
  heartbeatAt        DateTime? @db.Timestamptz(3)
  nextAttemptAt      DateTime? @db.Timestamptz(3)
  deadLetteredAt     DateTime? @db.Timestamptz(3)

  workspace      V2Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  client         V2ApiClient                @relation(fields: [clientId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  artifactRender V2ArtifactRenderOperation?

  @@unique([id, workspaceId])
  @@unique([workspaceId, clientId, idempotencyKey])
  @@index([workspaceId, createdAt(sort: Desc), id(sort: Desc)])
  @@index([workspaceId, deadLetteredAt(sort: Desc), createdAt(sort: Desc), id(sort: Desc)])
  @@index([workspaceId, status, updatedAt(sort: Desc)])
  @@index([workspaceId, type, createdAt(sort: Desc)])
  @@index([workspaceId, targetType, targetId])
  @@index([status, leaseExpiresAt, createdAt])
  @@index([status, nextAttemptAt, createdAt])
  @@map("public_operations")
}

model V2ArtifactRenderOperation {
  operationId            String    @id @db.VarChar(128)
  workspaceId            String    @db.VarChar(128)
  artifactId             String    @db.VarChar(128)
  manifestId             String    @db.VarChar(128)
  authorizationId        String    @db.VarChar(128)
  inputHash              String    @db.Char(64)
  outputKey              String?   @db.Text
  outputSha256           String?   @db.Char(64)
  outputByteSize         BigInt?
  outputWidth            Int?
  outputHeight           Int?
  outputFps              Float?
  outputDurationInFrames Int?
  outputCodec            String?   @db.VarChar(32)
  outputContainer        String?   @db.VarChar(32)
  outputAttempt          Int?
  outputCommittedAt      DateTime? @db.Timestamptz(3)
  outputRecordedAt       DateTime? @db.Timestamptz(3)

  workspace     V2Workspace                    @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  operation     V2PublicOperation              @relation(fields: [operationId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  artifact      V2MediaArtifact                @relation("ArtifactRenderTarget", fields: [artifactId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  manifest      V2MediaArtifactManifest        @relation(fields: [manifestId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  authorization V2MaterializationAuthorization @relation(fields: [authorizationId, workspaceId], references: [id, workspaceId], onDelete: Restrict)

  @@unique([operationId, workspaceId])
  @@index([workspaceId, artifactId, manifestId])
  @@index([workspaceId, authorizationId])
  @@map("artifact_render_operations")
}

model V2PublicEventOutbox {
  id            String    @id @db.Uuid
  workspaceId   String    @db.VarChar(128)
  type          String    @db.VarChar(96)
  version       String    @db.VarChar(32)
  occurredAt    DateTime  @db.Timestamptz(3)
  sequence      Int?
  actorClientId String?   @db.VarChar(128)
  actorUserId   String?   @db.VarChar(128)
  resourceType  String    @db.VarChar(32)
  resourceId    String    @db.VarChar(128)
  dataJson      String    @db.Text
  publishedAt   DateTime? @db.Timestamptz(3)
  createdAt     DateTime  @default(now()) @db.Timestamptz(3)

  workspace         V2Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  webhookDeliveries V2WebhookDelivery[]

  @@unique([id, workspaceId])
  @@index([publishedAt, occurredAt, id])
  @@index([workspaceId, publishedAt, occurredAt, id])
  @@index([workspaceId, occurredAt(sort: Asc), id(sort: Asc)])
  @@index([workspaceId, resourceType, resourceId, occurredAt(sort: Asc)])
  @@map("public_event_outbox")
}

model V2WebhookEndpoint {
  id                String    @id @db.Uuid
  workspaceId       String    @db.VarChar(128)
  url               String    @db.VarChar(2048)
  status            String    @default("pending-verification") @db.VarChar(32)
  createdByClientId String    @db.VarChar(80)
  createdAt         DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(3)
  verifiedAt        DateTime? @db.Timestamptz(3)
  suspendedAt       DateTime? @db.Timestamptz(3)
  revokedAt         DateTime? @db.Timestamptz(3)

  workspace      V2Workspace                      @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  createdBy      V2ApiClient                      @relation("WebhookEndpointCreator", fields: [createdByClientId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  secrets        V2WebhookSigningSecret[]
  subscriptions  V2WebhookSubscription[]
  challenges     V2WebhookVerificationChallenge[]
  replayReceipts V2WebhookReplayReceipt[]
  signingSecretRotations V2WebhookSigningSecretRotation[]

  @@unique([id, workspaceId])
  @@unique([workspaceId, url])
  @@index([workspaceId, status, createdAt(sort: Desc)])
  @@map("webhook_endpoints")
}

model V2WebhookSigningSecret {
  id          String    @id @db.Uuid
  workspaceId String    @db.VarChar(128)
  endpointId  String    @db.Uuid
  version     Int
  algorithm   String    @default("hmac-sha256") @db.VarChar(32)
  keyRef      String    @unique @db.VarChar(240)
  fingerprint String    @db.Char(64)
  status      String    @default("active") @db.VarChar(32)
  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  retiredAt   DateTime? @db.Timestamptz(3)
  usableUntil DateTime? @db.Timestamptz(3)
  revokedAt   DateTime? @db.Timestamptz(3)

  workspace V2Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  endpoint  V2WebhookEndpoint @relation(fields: [endpointId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  payload   V2WebhookSigningSecretPayload?

  @@unique([id, workspaceId])
  @@unique([id, workspaceId, endpointId, version])
  @@unique([endpointId, version])
  @@index([workspaceId, status, createdAt(sort: Desc)])
  @@index([workspaceId, status, usableUntil])
  @@index([endpointId, status, usableUntil])
  @@map("webhook_signing_secrets")
}

model V2WebhookSigningSecretPayload {
  secretId      String   @id @db.Uuid
  workspaceId   String   @db.VarChar(128)
  endpointId    String   @db.Uuid
  secretVersion Int
  algorithm     String   @db.VarChar(32)
  keyId         String   @db.VarChar(64)
  nonce         String   @db.VarChar(64)
  ciphertext    String   @db.Text
  authTag       String   @db.VarChar(64)
  createdAt     DateTime @default(now()) @db.Timestamptz(3)

  workspace V2Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  secret    V2WebhookSigningSecret @relation(fields: [secretId, workspaceId, endpointId, secretVersion], references: [id, workspaceId, endpointId, version], onDelete: Restrict)

  @@unique([secretId, workspaceId])
  @@unique([secretId, workspaceId, endpointId, secretVersion])
  @@index([workspaceId, endpointId, secretVersion])
  @@map("webhook_signing_secret_payloads")
}

model V2WebhookSigningSecretRotation {
  id                 String   @id @db.Uuid
  workspaceId        String   @db.VarChar(128)
  endpointId         String   @db.Uuid
  requestedByClientId String  @db.VarChar(80)
  previousSecretId   String   @db.Uuid
  candidateSecretId  String   @db.Uuid
  candidateVersion   Int
  algorithm          String   @default("hmac-sha256") @db.VarChar(32)
  keyRef             String   @unique @db.VarChar(240)
  fingerprint        String   @db.Char(64)
  status             String   @default("staged") @db.VarChar(32)
  overlapSeconds     Int
  payloadAlgorithm   String?  @db.VarChar(32)
  payloadKeyId       String?  @db.VarChar(64)
  payloadNonce       String?  @db.VarChar(64)
  payloadCiphertext  String?  @db.Text
  payloadAuthTag     String?  @db.VarChar(64)
  baseRevision       String   @db.Char(64)
  createdAt          DateTime @default(now()) @db.Timestamptz(3)
  expiresAt          DateTime @db.Timestamptz(3)
  activatedAt        DateTime? @db.Timestamptz(3)
  overlapUntil       DateTime? @db.Timestamptz(3)
  cancelledAt        DateTime? @db.Timestamptz(3)

  workspace V2Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  endpoint  V2WebhookEndpoint @relation(fields: [endpointId, workspaceId], references: [id, workspaceId], onDelete: Restrict)

  @@unique([id, workspaceId])
  @@unique([endpointId, candidateVersion])
  @@index([workspaceId, status, createdAt(sort: Desc)])
  @@index([workspaceId, status, expiresAt])
  @@index([endpointId, status, expiresAt])
  @@map("webhook_signing_secret_rotations")
}

model V2WebhookSubscription {
  id                    String    @id @db.Uuid
  workspaceId           String    @db.VarChar(128)
  endpointId            String    @db.Uuid
  status                String    @default("pending-verification") @db.VarChar(32)
  filterEventTypesJson  String    @db.Text
  filterResourceIdsJson String?   @db.Text
  filterHash            String    @db.Char(64)
  createdByClientId     String    @db.VarChar(80)
  createdAt             DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt             DateTime  @updatedAt @db.Timestamptz(3)
  pausedAt              DateTime? @db.Timestamptz(3)
  revokedAt             DateTime? @db.Timestamptz(3)

  workspace  V2Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  endpoint   V2WebhookEndpoint   @relation(fields: [endpointId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  createdBy  V2ApiClient         @relation("WebhookSubscriptionCreator", fields: [createdByClientId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  deliveries V2WebhookDelivery[]

  @@unique([id, workspaceId])
  @@unique([endpointId, filterHash])
  @@index([workspaceId, status, createdAt(sort: Desc)])
  @@map("webhook_subscriptions")
}

model V2WebhookDelivery {
  id             String    @id @db.Uuid
  workspaceId    String    @db.VarChar(128)
  subscriptionId String    @db.Uuid
  eventId        String    @db.Uuid
  status         String    @default("pending") @db.VarChar(32)
  attemptCount   Int       @default(0)
  maxAttempts    Int       @default(8)
  nextAttemptAt  DateTime  @db.Timestamptz(3)
  createdAt      DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime  @updatedAt @db.Timestamptz(3)
  completedAt    DateTime? @db.Timestamptz(3)
  deadLetteredAt DateTime? @db.Timestamptz(3)
  leaseOwner     String?   @db.VarChar(128)
  leaseTokenHash String?   @db.Char(64)
  leaseExpiresAt DateTime? @db.Timestamptz(3)
  heartbeatAt    DateTime? @db.Timestamptz(3)

  workspace    V2Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  subscription V2WebhookSubscription      @relation(fields: [subscriptionId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  event        V2PublicEventOutbox        @relation(fields: [eventId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  attempts     V2WebhookDeliveryAttempt[]

  @@unique([id, workspaceId])
  @@unique([subscriptionId, eventId])
  @@index([status, nextAttemptAt, createdAt])
  @@index([status, leaseExpiresAt, createdAt])
  @@index([workspaceId, status, createdAt(sort: Desc)])
  @@index([workspaceId, status, nextAttemptAt, id])
  @@index([workspaceId, status, leaseExpiresAt, id])
  @@index([workspaceId, createdAt(sort: Desc), id(sort: Desc)])
  @@index([workspaceId, eventId, createdAt(sort: Desc), id(sort: Desc)])
  @@index([workspaceId, subscriptionId, createdAt(sort: Desc), id(sort: Desc)])
  @@map("webhook_deliveries")
}

model V2WebhookDeliveryAttempt {
  id               String    @id @db.Uuid
  workspaceId      String    @db.VarChar(128)
  deliveryId       String    @db.Uuid
  attemptNumber    Int
  status           String    @default("scheduled") @db.VarChar(32)
  scheduledAt      DateTime  @db.Timestamptz(3)
  startedAt        DateTime? @db.Timestamptz(3)
  completedAt      DateTime? @db.Timestamptz(3)
  responseStatus   Int?
  responseBodyHash String?   @db.Char(64)
  errorCode        String?   @db.VarChar(64)
  createdAt        DateTime  @default(now()) @db.Timestamptz(3)

  workspace V2Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  delivery  V2WebhookDelivery @relation(fields: [deliveryId, workspaceId], references: [id, workspaceId], onDelete: Cascade)

  @@unique([id, workspaceId])
  @@unique([deliveryId, attemptNumber])
  @@index([workspaceId, status, scheduledAt])
  @@map("webhook_delivery_attempts")
}

model V2WebhookVerificationChallenge {
  id           String    @id @db.Uuid
  workspaceId  String    @db.VarChar(128)
  endpointId   String    @db.Uuid
  tokenHash    String    @unique @db.Char(64)
  status       String    @default("pending") @db.VarChar(32)
  attemptCount Int       @default(0)
  maxAttempts  Int       @default(5)
  expiresAt    DateTime  @db.Timestamptz(3)
  createdAt    DateTime  @default(now()) @db.Timestamptz(3)
  verifiedAt   DateTime? @db.Timestamptz(3)
  failedAt     DateTime? @db.Timestamptz(3)

  workspace V2Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  endpoint  V2WebhookEndpoint @relation(fields: [endpointId, workspaceId], references: [id, workspaceId], onDelete: Cascade)

  @@unique([id, workspaceId])
  @@index([endpointId, status, createdAt(sort: Desc)])
  @@index([status, expiresAt])
  @@map("webhook_verification_challenges")
}

model V2WebhookReplayReceipt {
  id                 String   @id @db.Uuid
  workspaceId        String   @db.VarChar(128)
  endpointId         String   @db.Uuid
  eventId            String   @db.Uuid
  signatureTimestamp DateTime @db.Timestamptz(3)
  receivedAt         DateTime @db.Timestamptz(3)
  expiresAt          DateTime @db.Timestamptz(3)

  workspace V2Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  endpoint  V2WebhookEndpoint @relation(fields: [endpointId, workspaceId], references: [id, workspaceId], onDelete: Cascade)

  @@unique([id, workspaceId])
  @@unique([endpointId, eventId])
  @@index([workspaceId, expiresAt])
  @@map("webhook_replay_receipts")
}

model V2WebhookWorkerShardLease {
  id               String   @id @db.Uuid
  poolId           String   @db.VarChar(128)
  shardIndex       Int
  shardCount       Int
  leaseOwner       String   @db.VarChar(128)
  leaseTokenHash   String   @db.Char(64)
  heartbeatAt      DateTime @db.Timestamptz(3)
  leaseExpiresAt   DateTime @db.Timestamptz(3)
  createdAt        DateTime @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime @updatedAt @db.Timestamptz(3)

  @@unique([poolId, shardIndex])
  @@unique([poolId, leaseOwner])
  @@index([poolId, leaseExpiresAt, shardIndex])
  @@map("webhook_worker_shard_leases")
}
